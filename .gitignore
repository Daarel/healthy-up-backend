# Salin .env.example → .env lalu isi nilainya secara lokal.
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
# .env.example TIDAK diabaikan — sengaja di-commit sebagai template

# ── Test coverage ─────────────────────────────────────────────────────────────
coverage/

# ── OS / editor ───────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.idea/

# ── Prisma generated client ───────────────────────────────────────────────────
