.vite/
.cache/
.turbo/

# ── Logs ─────────────────────────────────────────────────────────────────────
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# ── Environment files ─────────────────────────────────────────────────────────
