# Salin file ini menjadi .env lalu isi dengan nilai yang sesuai
# cp .env.example .env

# ── Database ──────────────────────────────────────────────────────────────────
# Connection string PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require"

# ── App ───────────────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT=5001

# ── JWT ───────────────────────────────────────────────────────────────────────
# Generate dengan: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET="your-secret-key-here"
JWT_EXPIRES_IN="7d"

# ── Admin ─────────────────────────────────────────────────────────────────────
# UUID dari user yang diberi akses admin (pisahkan dengan koma jika lebih dari satu)
ADMIN_USER_IDS="uuid-user-admin-1,uuid-user-admin-2"
