// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

// --- ENUMS ---
enum ActivityCategory {
  physical
  mental
  nutrition
}

enum MissionStatus {
  assigned
  in_progress
  completed
  failed
}

enum GenderType {
  male
  female
}

enum VerificationStatus {
  pending
  approved
  rejected
}

enum Role {
  admin
  user
}

enum Title {
  pemula // level 1 - 4
  penggerak // Level 5 - 9
  pejuang_sehat // Level 10 - 14
  kesatria_bugar // Level 15 - 19
  master_vitalitas // Level 20 - 24
  legenda // Level 25+
}

// --- MODELS ---
model User {
  id             String @id @default(uuid()) @db.Uuid
  username       String @unique @db.VarChar(50)
  email          String @unique @db.VarChar(255)
  password       String @db.Text
  role           Role   @default(user)
  profilePicture String @default("https://ui-avatars.com/api/?name=New+User&background=random&color=fff")

  rankTitle        Title @default(pemula)
  level            Int   @default(1)
  experiencePoints Int   @default(0)
  rewardPoints     Int   @default(0)
  streakCount      Int   @default(0)

  lastLoginAt DateTime? @db.Timestamptz
  createdAt   DateTime  @default(now()) @db.Timestamptz
  updatedAt   DateTime  @updatedAt @db.Timestamptz

  // Relations
  healthProfile HealthProfile?
  missions      Mission[]
  otpCode       OtpCode?
  weightLogs    WeightLog[]
  calorieLogs   calorieLog[]
  userRewards   UserReward[]

  @@index([email])
  @@index([level])
}

model HealthProfile {
  id         String     @id @default(uuid()) @db.Uuid
  userId     String     @unique @db.Uuid
  gender     GenderType
  age        Int
  weightKg   Decimal    @db.Decimal(5, 2)
  heightCm   Decimal    @db.Decimal(5, 2)
  goalWeight Decimal    @db.Decimal(5, 2)
  updatedAt  DateTime   @default(now()) @updatedAt @db.Timestamptz

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Mission {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid

  title           String           @db.VarChar(100)
  description     String           @db.Text
  category        ActivityCategory
  difficultyScore Int
  caloriesImpact  Int

  scheduledDate      DateTime           @db.Date
  status             MissionStatus      @default(assigned)
  verificationStatus VerificationStatus @default(pending)
  rejectionReason    String?            @db.Text

  xpReward       Int
  pointsReward   Int
  proofImagePath String? @db.Text

  completedAt DateTime? @db.Timestamptz
  createdAt   DateTime  @default(now()) @db.Timestamptz
  updatedAt   DateTime  @updatedAt @db.Timestamptz

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, scheduledDate])
  @@index([userId, status])
}

model Reward {
  id            String   @id @default(uuid()) @db.Uuid
  name          String   @db.VarChar(255)
  pointsCost    Int
  stockQuantity Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now()) @db.Timestamptz

  // Relations
  userRewards UserReward[]
}

model UserReward {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @db.Uuid
  rewardId       String   @db.Uuid
  redemptionCode String   @unique @db.VarChar(100)
  redeemedAt     DateTime @default(now()) @db.Timestamptz

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  reward Reward @relation(fields: [rewardId], references: [id], onDelete: Restrict)

  @@index([userId, rewardId])
}

model WeightLog {
  id       String   @id @default(uuid()) @db.Uuid
  userId   String   @db.Uuid
  weight   Float
  loggedAt DateTime @default(now()) @db.Timestamptz

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model calorieLog {
  id       String   @id @default(uuid()) @db.Uuid
  userId   String   @db.Uuid
  weight   Float
  loggedAt DateTime @default(now()) @db.Timestamptz

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model OtpCode {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now()) @db.Timestamptz

  // Relations
  userEmail User @relation(fields: [email], references: [email], onDelete: Cascade)
}
