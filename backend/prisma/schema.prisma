// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- ENUMS ---
enum ActivityCategory {
  physical
  mental
  nutrition
}

enum MissionStatus {
  assigned
  in_progress
  completed
  failed
}

enum GenderType {
  male
  female
}

enum VerificationStatus {
  pending
  approved
  rejected
}

// --- MODELS ---
model User {
  id       String @id @default(uuid()) @db.Uuid
  username String @unique @db.VarChar(50)
  email    String @unique @db.VarChar(255)
  password String @db.Text

  rankTitle        String @default("pemula") @db.VarChar(20)
  level            Int    @default(1)
  experiencePoints Int    @default(0)
  rewardPoints     Int    @default(0)
  streakCount      Int    @default(0)

  lastLoginAt DateTime? @db.Timestamptz
  createdAt   DateTime  @default(now()) @db.Timestamptz
  updatedAt   DateTime  @updatedAt @db.Timestamptz

  // Relations
  healthProfile HealthProfile?
  missions      Mission[]
  otpCode       OtpCode?
  weightLogs    WeightLog[]
  userRewards   UserReward[]

  @@index([email])
  @@index([level])
}

model HealthProfile {
  id         String     @id @default(uuid()) @db.Uuid
  userId     String     @unique @db.Uuid
  gender     GenderType
  weightKg   Decimal    @db.Decimal(5, 2)
  heightCm   Decimal    @db.Decimal(5, 2)
  goalWeight Decimal    @db.Decimal(5, 2)
  updatedAt  DateTime   @default(now()) @updatedAt @db.Timestamptz

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model Mission {
  id     String @id @default(uuid()) @db.Uuid
  userId String @db.Uuid

  title           String           @db.VarChar(100)
  description     String           @db.Text
  category        ActivityCategory
  difficultyScore Int
  caloriesImpact  Int

  scheduledDate      DateTime           @db.Date
  status             MissionStatus      @default(assigned)
  verificationStatus VerificationStatus @default(pending)
  rejectionReason    String?            @db.Text

  xpReward       Int
  pointsReward   Int
  aiNarrative    String? @db.Text
  proofImagePath String? @db.Text

  completedAt DateTime? @db.Timestamptz
  createdAt   DateTime  @default(now()) @db.Timestamptz
  updatedAt   DateTime  @updatedAt @db.Timestamptz

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, scheduledDate])
  @@index([userId, status])
}

model Reward {
  id            String   @id @default(uuid()) @db.Uuid
  name          String   @db.VarChar(255)
  pointsCost    Int
  stockQuantity Int      @default(0)
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now()) @db.Timestamptz

  // Relations
  userRewards UserReward[]
}

model UserReward {
  id             String   @id @default(uuid()) @db.Uuid
  userId         String   @db.Uuid
  rewardId       String   @db.Uuid
  redemptionCode String   @unique @db.VarChar(100)
  redeemedAt     DateTime @default(now()) @db.Timestamptz

  // Relations
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  reward Reward @relation(fields: [rewardId], references: [id], onDelete: Restrict)

  @@index([userId, rewardId])
}

model WeightLog {
  id       String   @id @default(uuid()) @db.Uuid
  userId   String   @db.Uuid
  weight   Float
  loggedAt DateTime @default(now()) @db.Timestamptz

  // Relations
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model OtpCode {
  id        String   @id @default(uuid()) @db.Uuid
  email     String   @unique
  code      String
  expiresAt DateTime
  createdAt DateTime @default(now()) @db.Timestamptz

  // Relations
  userEmail User @relation(fields: [email], references: [email], onDelete: Cascade)
}
